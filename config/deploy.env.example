# GanitSūtram Production Environment Template
# Project: GanitSūtram
# Author: Jawahar R Mallah
# Company: AITDL | aitdl.com
# Vikram Samvat: VS 2082
# Gregorian: 2026-03-07

# Server
PORT=3000
NODE_ENV=production

# JWT
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Database (Railway volume path for SQLite)
DB_PATH=/data/ganitsutram.db

# PostgreSQL (Uncomment to use PostgreSQL instead of SQLite)
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# CORS (production domains only)
ALLOWED_ORIGINS=https://ganitsutram.com,https://discover.ganitsutram.com,https://learning.ganitsutram.com,https://map.ganitsutram.com,https://lab.ganitsutram.com,https://solve.ganitsutram.com
