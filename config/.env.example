# GanitSūtram: Environment Template
# Copy this to .env and fill in your actual credentials.
# NEVER commit the real .env to version control.

# Database (Supabase / PostgreSQL)
# For Render production, use the Session Pooler URL (Port 5432)
DATABASE_URL=postgresql://your_user:your_password@your_host:5432/postgres

# App Settings
PORT=3000
NODE_ENV=development
BCRYPT_ROUNDS=12

# Authentication
JWT_SECRET=your_super_secret_jwt_string_here
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_DAYS=30

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=GanitSūtram <noreply@ganitsutram.com>

# Reset Tokens
RESET_TOKEN_EXPIRES_MINUTES=30
