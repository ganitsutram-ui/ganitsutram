{
  "name": "ganitsutram",
  "version": "1.0.0",
  "description": "GaṇitSūtram - Split Architecture (GitHub Pages + Railway)",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend-next && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && node server.js",
    "dev:frontend": "cd frontend-next && npm run dev -- -p 3005",
    "build": "cd frontend-next && npm run build",
    "start": "concurrently \"npm run dev:backend\" \"cd frontend-next && npm run start -- -p 3005\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
